      "targets": [
        {
          "query": "data = from(bucket: \"sensors\")\n  |> range(start: -1h)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"ambient\")\n  |> filter(fn: (r) => r[\"_field\"] == \"pressure\")\n\nfirst_val = data |> first() |> set(key: \"_join\", value: \"1\")\nlast_val  = data |> last()  |> set(key: \"_join\", value: \"1\")\n\njoin(tables: {f: first_val, l: last_val}, on: [\"_join\"])\n  |> map(fn: (r) => ({\n      _value: r._value_l - r._value_f\n  }))",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "ambient-influxdb"
          },
          "query": "data = from(bucket: \"sensors\")\n  |> range(start: -3h)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"ambient\")\n  |> filter(fn: (r) => r[\"_field\"] == \"pressure\")\n\nfirst_val = data |> first() |> set(key: \"_join\", value: \"1\")\nlast_val  = data |> last()  |> set(key: \"_join\", value: \"1\")\n\njoin(tables: {f: first_val, l: last_val}, on: [\"_join\"])\n  |> map(fn: (r) => ({\n      _value: r._value_l - r._value_f\n      }))",
          "refId": "B"
        }
